    "cover": {
      "projectId": "proj_psa_demo_001",
      "background": "PSA BDP Global Ocean Freight division requires a comprehensive digital transformation to modernize operations, improve tracking, and enhance customer experience. Current systems are legacy-based and lack real-time visibility.",
      "objectives": [
        "Implement real-time freight tracking system",
        "Automate booking and documentation processes",
        "Integrate with existing ERP and CRM systems",
        "Provide mobile accessibility for field staff",
        "Improve reporting and analytics capabilities"
      ],
      "successCriteria": [
        "95% booking automation rate",
        "Real-time tracking for 100% of shipments",
        "50% reduction in manual data entry",
        "Customer satisfaction score above 4.5/5"
      ],
      "risks": [
        "Integration complexity with legacy systems",
        "User adoption resistance",
        "Data migration challenges"
      ],
      "updatedAt": "2024-01-01T00:00:00Z"
    },
